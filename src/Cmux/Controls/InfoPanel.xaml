<UserControl x:Class="Cmux.Controls.InfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320">

    <Border CornerRadius="12,0,0,12" Padding="0"
            Background="{StaticResource OverlayBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#000000" Opacity="0.3" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12,0,0,0" Padding="0">
                <Grid Margin="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="System Info" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource ForegroundBrush}" />
                        <TextBlock x:Name="SummaryText" Text="" FontSize="10"
                                   Foreground="{StaticResource ForegroundDimBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource IconButton}" ToolTip="Refresh"
                            Click="Refresh_Click">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel>

                    <!-- Performance Section -->
                    <Expander IsExpanded="False" Margin="0,0,0,8">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="PerfSummary" Text="Performance" FontSize="12"
                                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel Margin="24,4,0,0">
                            <TextBlock x:Name="PerfDetails" Text="" FontSize="11" FontFamily="Cascadia Mono"
                                       Foreground="{StaticResource ForegroundDimBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Expander>

                    <!-- Ports Section -->
                    <Expander IsExpanded="True" Margin="0,0,0,8">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="PortsSummary" Text="Ports" FontSize="12"
                                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel x:Name="PortsList" Margin="24,4,0,0" />
                    </Expander>

                    <!-- Sessions Section -->
                    <Expander IsExpanded="False" Margin="0,0,0,8">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE737;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="SessionsSummary" Text="Sessions" FontSize="12"
                                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel x:Name="SessionsList" Margin="24,4,0,0" />
                    </Expander>

                    <!-- Git Section -->
                    <Expander IsExpanded="False" Margin="0,0,0,8">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8AD;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="GitSummary" Text="Git" FontSize="12"
                                           Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel x:Name="GitList" Margin="24,4,0,0" />
                    </Expander>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
